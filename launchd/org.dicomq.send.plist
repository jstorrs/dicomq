<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.dicomq.send</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/dicomq-send</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>DICOMQ_SPOOL</key>
    <string>/var/spool/dicomq</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>UserName</key>
  <string>_dicomq</string>
</dict>
</plist>
