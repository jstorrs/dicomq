<?xml version="1.0" encoding="UTF-8"?>
<!-- One dicomq-recv per association via launchd's inetd-compatibility
     mode: Wait=false hands each accepted connection to a fresh process
     on fd 0, exactly like systemd Accept=yes. For a TLS listener, add
     the TLS flag (see dicomq-recv usage) as a ProgramArguments entry. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.dicomq.recv</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/dicomq-recv</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>DICOMQ_SPOOL</key>
    <string>/var/spool/dicomq</string>
  </dict>
  <key>Sockets</key>
  <dict>
    <key>Listener</key>
    <dict>
      <key>SockServiceName</key>
      <string>11112</string>
      <key>SockType</key>
      <string>stream</string>
    </dict>
  </dict>
  <key>inetdCompatibility</key>
  <dict>
    <key>Wait</key>
    <false/>
  </dict>
  <key>UserName</key>
  <string>_dicomqrecv</string>
</dict>
</plist>
