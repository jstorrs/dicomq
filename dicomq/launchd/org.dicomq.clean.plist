<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>org.dicomq.clean</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/dicomq-clean</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>DICOMQ_SPOOL</key>
    <string>/var/spool/dicomq</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>
  <key>UserName</key>
  <string>_dicomq</string>
</dict>
</plist>
