[Unit]
Description=dicomq queue runner
After=network.target

[Service]
ExecStart=/usr/local/bin/dicomq-send
Restart=always
RestartSec=5
Environment=DICOMQ_SPOOL=/var/spool/dicomq
User=dicomq
Group=dicomq
ReadWritePaths=/var/spool/dicomq
ProtectSystem=strict
PrivateTmp=yes
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
